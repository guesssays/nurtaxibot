{
  "name": "wb-taxi-registration-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Telegram bot for WB Taxi driver registration control on Netlify Functions.",
  "scripts": {
    "build": "npm run prisma:generate",
    "dev": "netlify dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.5",
    "@prisma/client": "^6.18.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "netlify-cli": "^24.6.2",
    "prisma": "^6.18.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
